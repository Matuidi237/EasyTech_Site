---
import type { Lang } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const r = t.realisations;
---

<!-- Hero -->
<section class="real-hero" aria-labelledby="real-hero-title">
  <div class="container real-hero-inner">
    <p class="eyebrow">{r.eyebrow}</p>
    <h1 id="real-hero-title">{r.title}</h1>
    <p class="real-hero-subtitle">{r.subtitle}</p>
  </div>
</section>

<!-- Projects -->
<section class="real-projects" aria-label={r.eyebrow}>
  <div class="container">
    {r.projects.map((p: any, i: number) => (
      <article class={`project-card reveal ${i % 2 === 1 ? "project-card--reverse" : ""}`}>

        <!-- Screenshot -->
        <div class="project-visual">
          <div class="project-screen">
            <div class="project-screen-bar" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
            <img
              src={p.image}
              alt={`Capture d'écran de la plateforme ${p.name}`}
              width="700"
              height="420"
              loading="lazy"
            />
          </div>
          {p.url && (
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="project-visit-btn">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="16" height="16"><path d="M11 3h6v6M17 3l-8 8M8 5H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-4"/></svg>
              {r.visitLabel}
            </a>
          )}
        </div>

        <!-- Info -->
        <div class="project-info">
          <!-- Meta -->
          <div class="project-meta">
            <span class="project-sector">{p.sector}</span>
            <div class="project-metric">
              <span class="metric-value">{p.metric.value}</span>
              <span class="metric-label">{p.metric.label}</span>
            </div>
          </div>

          <h2 class="project-name">{p.name}</h2>
          <p class="project-client">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" width="14" height="14"><path d="M10 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM3 18a7 7 0 0 1 14 0"/></svg>
            {p.client}
          </p>

          <p class="project-description">{p.description}</p>

          <!-- Tags -->
          <ul class="project-tags">
            {p.tags.map((tag: string) => (
              <li class="project-tag">{tag}</li>
            ))}
          </ul>

          <!-- Challenge / Solution -->
          <div class="project-details">
            <div class="detail-block">
              <div class="detail-icon detail-icon--challenge" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M12 9v4M12 17h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/></svg>
              </div>
              <div>
                <p class="detail-label">{r.challengeLabel}</p>
                <p class="detail-text">{p.challenge}</p>
              </div>
            </div>
            <div class="detail-block">
              <div class="detail-icon detail-icon--solution" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="9"/><path d="M8 12.5l3 3 5-5.5"/></svg>
              </div>
              <div>
                <p class="detail-label">{r.solutionLabel}</p>
                <p class="detail-text">{p.solution}</p>
              </div>
            </div>
          </div>
        </div>

      </article>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="real-cta reveal">
  <div class="container">
    <div class="real-cta-inner">
      <div class="real-cta-deco" aria-hidden="true"></div>
      <h2>{r.ctaTitle}</h2>
      <a href={`/${lang}/contact`} class="btn btn-primary">{r.cta}</a>
    </div>
  </div>
</section>

<style>
  /* ══ HERO ══ */
  .real-hero {
    padding: 5rem 0 3.5rem;
    background: linear-gradient(160deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .real-hero-inner { max-width: 680px; }
  .real-hero h1 { font-size: clamp(2rem, 4.5vw, 3rem); margin: 0.75rem 0 1.25rem; line-height: 1.15; }
  .real-hero-subtitle { font-size: 1.1rem; color: var(--color-text-secondary); line-height: 1.75; margin: 0; }

  /* ══ PROJECTS ══ */
  .real-projects { padding: 4rem 0 2rem; }
  .real-projects .container { display: flex; flex-direction: column; gap: 5rem; }

  .project-card {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }
  .project-card--reverse { direction: rtl; }
  .project-card--reverse > * { direction: ltr; }

  /* Screenshot frame */
  .project-visual { position: relative; }
  .project-screen {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    box-shadow: 0 24px 56px rgba(2, 33, 121, 0.10), 0 4px 12px rgba(0,0,0,0.06);
  }
  .project-screen-bar {
    height: 28px;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0 10px;
  }
  .project-screen-bar span {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--color-border);
  }
  .project-screen-bar span:nth-child(1) { background: #ff5f57; }
  .project-screen-bar span:nth-child(2) { background: #febc2e; }
  .project-screen-bar span:nth-child(3) { background: #28c840; }
  .project-screen img { width: 100%; height: auto; display: block; }

  .project-visit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.2s;
  }
  .project-visit-btn:hover { gap: 0.65rem; text-decoration: underline; }

  /* Info column */
  .project-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .project-sector {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .project-metric {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }
  .metric-value {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }
  .metric-label {
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    margin-top: 0.1rem;
  }

  .project-name {
    font-size: 1.65rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .project-client {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }
  .project-client svg { flex-shrink: 0; opacity: 0.6; }
  .project-description {
    font-size: 0.97rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin-bottom: 1.75rem;
  }
  .project-tag {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    background: var(--color-bg-secondary);
  }

  /* Challenge / Solution */
  .project-details { display: flex; flex-direction: column; gap: 1rem; }
  .detail-block {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    padding: 1rem 1.1rem;
    border-radius: 10px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
  }
  .detail-icon {
    flex-shrink: 0;
    width: 36px; height: 36px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .detail-icon--challenge { background: rgba(234, 88, 12, 0.08); color: #ea580c; }
  .detail-icon--solution  { background: rgba(22, 163, 74, 0.08); color: #16a34a; }
  .detail-label {
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--color-text-secondary); margin-bottom: 0.25rem;
  }
  .detail-text { font-size: 0.88rem; color: var(--color-text-secondary); line-height: 1.65; margin: 0; }

  /* Separator between projects */
  .project-card + .project-card {
    padding-top: 5rem;
    border-top: 1px solid var(--color-border);
  }

  /* ══ CTA ══ */
  .real-cta { padding: 3rem 0 4rem; }
  .real-cta-inner {
    position: relative;
    text-align: center;
    padding: 3.5rem 2rem;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    overflow: hidden;
    color: #fff;
  }
  .real-cta-deco {
    position: absolute;
    width: 320px; height: 320px;
    border-radius: 50%;
    border: 60px solid rgba(255,255,255,0.06);
    top: -100px; right: -80px;
    pointer-events: none;
  }
  .real-cta-inner h2 { color: #fff; font-size: clamp(1.4rem, 3vw, 2rem); margin-bottom: 1.75rem; position: relative; z-index: 1; }
  .real-cta-inner .btn-primary { background: #fff; color: var(--color-primary); position: relative; z-index: 1; }
  .real-cta-inner .btn-primary:hover { background: #f1f1f1; }

  /* ══ RESPONSIVE ══ */
  @media (max-width: 900px) {
    .project-card { grid-template-columns: 1fr; gap: 2rem; }
    .project-card--reverse { direction: ltr; }
    .project-metric { align-items: flex-start; }
    .project-meta { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
  @media (max-width: 600px) {
    .real-hero { padding: 3.5rem 0 2.5rem; }
    .real-projects .container { gap: 3.5rem; }
    .project-card + .project-card { padding-top: 3.5rem; }
    .project-name { font-size: 1.35rem; }
  }
</style>
