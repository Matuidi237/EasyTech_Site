<script is:inline>
(function () {
  /* ── Count-up animation ── */
  function parseMetric(raw) {
    var prefix = raw.match(/^[^0-9]*/)[0];
    var suffix = raw.match(/[^0-9]*$/)[0];
    var num = parseFloat(raw.replace(/[^0-9.]/g, ''));
    return { prefix: prefix, suffix: suffix, num: isNaN(num) ? 0 : num };
  }
  function animateCount(el) {
    var raw = el.getAttribute('data-value') || el.textContent;
    var p = parseMetric(raw);
    var duration = 1800; var start = null;
    function step(ts) {
      if (!start) start = ts;
      var progress = Math.min((ts - start) / duration, 1);
      var ease = 1 - Math.pow(1 - progress, 3);
      el.textContent = p.prefix + Math.round(ease * p.num) + p.suffix;
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  var countObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) { animateCount(entry.target); countObs.unobserve(entry.target); }
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.metric-count').forEach(function (el) { countObs.observe(el); });

  /* ── Timeline highlight animation ── */
  var tlItems = Array.prototype.slice.call(document.querySelectorAll('.tl-item'));
  var tlLine = document.querySelector('.timeline');
  if (!tlItems.length) return;

  var tlIdx = 0;
  var tlTimer = null;
  var tlStarted = false;

  function setActiveTl(i) {
    tlItems.forEach(function (el, idx) {
      el.classList.remove('tl-active');
      if (idx < i) el.classList.add('tl-done');
      else el.classList.remove('tl-done');
    });
    tlItems[i].classList.add('tl-active');
    tlIdx = i;
    /* animate progress line width */
    if (tlLine) {
      var pct = tlItems.length > 1 ? (i / (tlItems.length - 1)) * 100 : 100;
      tlLine.style.setProperty('--tl-progress', pct + '%');
    }
  }

  function startTl() {
    if (tlTimer) return;
    setActiveTl(0);
    tlTimer = setInterval(function () {
      var next = (tlIdx + 1) % tlItems.length;
      setActiveTl(next);
    }, 2600);
  }

  /* Start when timeline enters viewport */
  var tlObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting && !tlStarted) {
        tlStarted = true;
        startTl();
        tlObs.disconnect();
      }
    });
  }, { threshold: 0.2 });

  if (tlLine) tlObs.observe(tlLine);
})();
</script>
