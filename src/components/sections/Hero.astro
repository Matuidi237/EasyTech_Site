---
import type { Lang } from "../../i18n/utils";
import { useTranslations, highlightBrand } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="accueil" class="hero" aria-labelledby="hero-title">
  <div class="circle-deco hero-circle-1" aria-hidden="true"></div>
  <div class="circle-deco circle-delay hero-circle-2" aria-hidden="true"></div>
  <div class="container hero-top">
    <p class="hero-trust-bar reveal">{t.hero.trustBar}</p>
    <div class="hero-content">
      <div class="hero-text reveal">
        <h1 id="hero-title">{t.hero.title}</h1>
        <p class="hero-subtitle" set:html={highlightBrand(t.hero.subtitle)} />
        <div class="hero-cta">
          <a href={`/${lang}/contact`} class="btn btn-primary">{t.hero.ctaPrimary}</a>
          <a href={`/${lang}/services`} class="btn btn-secondary">{t.hero.ctaSecondary}</a>
        </div>
      </div>
      <figure class="hero-visual reveal">
        <img src="/images/hero/hero-accueil.jpg" alt={t.hero.heroImageAlt} loading="eager" width="640" height="760" />
      </figure>
    </div>
  </div>

  <div class="container hero-platforms" style="position: relative;">
    <div class="circle-deco circle-fill hero-circle-3" aria-hidden="true"></div>
    <h2 class="carousel-title">{t.hero.platformsTitle}</h2>
    <div class="platforms-grid">
      {t.hero.platforms.map((p: any) => {
        const Tag = p.url ? "a" : "div";
        const linkProps = p.url ? { href: p.url, target: "_blank", rel: "noopener noreferrer" } : {};
        return (
          <Tag class={`platform-card ${!p.url ? "is-disabled" : ""}`} {...linkProps}>
            <div class="platform-thumb">
              <img src={p.image} alt={p.name} width="400" height="260" loading="lazy" />
            </div>
            <div class="platform-info">
              <h3>{p.name}</h3>
              <p>{p.description}</p>
              {!p.url && <span class="platform-soon">{t.hero.comingSoon}</span>}
            </div>
          </Tag>
        );
      })}
    </div>

    <h2 class="carousel-title">{t.hero.partnersTitle}</h2>
    <div class="carousel" aria-label={t.hero.partnersTitle}>
      <div class="carousel-track">
        {t.hero.partners.map((p: any) => (
          <div class="partner-logo">
            <img src={p.logo} alt={p.name} loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <ul class="trust-metrics">
      {t.hero.metrics.map((m: any) => (
        <li><strong>{m.value}</strong><span>{m.label}</span></li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero { position: relative; padding-top: 2.5rem; overflow: hidden; }

  .hero-circle-1 { top: -70px; left: -70px; width: 240px; height: 240px; }
  .hero-circle-2 { top: 40%; right: -60px; width: 180px; height: 180px; }

  .hero-top { position: relative; z-index: 1; }

  .hero-content { display: grid; grid-template-columns: 1fr 1.2fr; gap: 3.5rem; align-items: center; margin: 1.5rem 0 4rem; }
  .hero-trust-bar { color: var(--color-text-secondary); font-size: 0.9rem; margin-bottom: 1rem; font-weight: 500; }
  .hero-subtitle { margin: 1.25rem 0 1.75rem; font-size: 1.1rem; max-width: 520px; }

  .hero-visual {
    position: relative;
    border-radius: 28px 110px 28px 28px;
    overflow: hidden;
    box-shadow: 0 30px 60px -20px rgba(2, 33, 121, 0.35);
  }
  .hero-visual img {
    width: 100%;
    height: 100%;
    min-height: 480px;
    max-height: 640px;
    object-fit: cover;
    display: block;
  }

  .hero-circle-3 { top: -30px; right: 12%; width: 150px; height: 150px; }
  .carousel-title { position: relative; z-index: 1; font-size: 1.1rem; margin: 2rem 0 1rem; color: var(--color-text-secondary); font-weight: 600; }

  .platforms-grid { position: relative; z-index: 1; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem; }
  .platform-card {
    display: flex;
    flex-direction: column;
    border-radius: 18px;
    background: var(--color-bg-secondary);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .platform-card:not(.is-disabled) { cursor: pointer; }
  .platform-card:not(.is-disabled):hover,
  .platform-card:not(.is-disabled):focus-visible {
    transform: translateY(-6px);
    box-shadow: 0 22px 40px -16px rgba(2, 33, 121, 0.28);
    border-color: var(--color-accent);
  }
  .platform-card.is-disabled { cursor: default; }

  .platform-thumb {
    aspect-ratio: 16 / 10;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem;
    border-bottom: 1px solid var(--color-border);
  }
  .platform-thumb img { width: 100%; height: 100%; object-fit: contain; border-radius: 8px; }

  .platform-info { padding: 1.25rem 1.5rem 1.5rem; }
  .platform-info h3 { margin-bottom: 0.4rem; display: flex; align-items: center; gap: 0.5rem; }
  .platform-info p { font-size: 0.9rem; margin: 0; }
  .platform-soon { display: inline-block; margin-top: 0.75rem; font-size: 0.78rem; font-weight: 600; color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: 999px; padding: 0.25rem 0.7rem; }

  .carousel { overflow: hidden; }
  .partner-logo {
    min-width: 160px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.25rem;
  }
  .partner-logo img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; }
  .trust-metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; list-style: none; margin: 3.5rem 0; border-top: 1px solid var(--color-border); }
  .trust-metrics li { padding: 1.5rem 1.25rem 0; border-left: 1px solid var(--color-border); }
  .trust-metrics li:first-child { border-left: none; }
  .trust-metrics strong { display: block; font-size: 2.25rem; font-weight: 800; color: var(--color-accent); }
  .trust-metrics span { color: var(--color-text-secondary); font-size: 0.9rem; }

  @media (max-width: 900px) {
    .hero-content { grid-template-columns: 1fr; }
    .hero-visual { order: -1; margin-bottom: 1rem; border-radius: 20px 60px 20px 20px; }
    .platforms-grid { grid-template-columns: 1fr; }
    .trust-metrics { grid-template-columns: repeat(2, 1fr); }
    .trust-metrics li { border-left: none; border-top: 1px solid var(--color-border); padding: 1.25rem 0 0; }
    .trust-metrics li:nth-child(odd) { border-left: none; }
  }

  @media (max-width: 640px) {
    .platforms-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline src="/scripts/carousel.js"></script>
<script is:inline src="/scripts/counter.js"></script>
