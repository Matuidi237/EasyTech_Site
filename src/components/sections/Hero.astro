---
import type { Lang } from "../../i18n/utils";
import { useTranslations, highlightBrand } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="accueil" class="hero" aria-labelledby="hero-title">
  <div class="hero-bg" aria-hidden="true">
    <img src="/images/hero/hero-easytech2.jpg" alt="" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-top">
    <div class="hero-badge">{t.hero.trustBar}</div>
    <h1 id="hero-title" class="hero-title">
      {t.hero.title}<br /><span class="hero-title-accent">{t.hero.titleLine2}</span>
    </h1>
    <p class="hero-subtitle" set:html={highlightBrand(t.hero.subtitle)} />
    <div class="hero-cta">
      <a href={`/${lang}/contact`} class="btn btn-primary">{t.hero.ctaPrimary}</a>
      <a href={`/${lang}/services`} class="btn btn-secondary btn-secondary--light">{t.hero.ctaSecondary}</a>
    </div>
  </div>

  <div class="container hero-platforms">
    <p class="platforms-label">{t.hero.platformsTitle}</p>
    <div class="pc-outer">
      <button class="pc-arrow pc-arrow--prev" aria-label="Précédent" id="pcPrev">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="pc-viewport">
        <div class="platforms-grid" id="platformsGrid">
          {t.hero.platforms.map((p: any) => (
            <div class="platform-card">
              <div class="platform-thumb">
                <img src={p.image} alt={p.name} loading="eager" />
              </div>
              <div class="platform-info">
                <h3>{p.name}</h3>
                <p>{p.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <button class="pc-arrow pc-arrow--next" aria-label="Suivant" id="pcNext">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
    <div class="pc-dots" id="pcDots"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    object-position: center top;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgba(8,18,36,0.82) 45%, rgba(8,18,36,0.40) 100%);
  }

  .hero-top {
    position: relative;
    z-index: 1;
    padding-top: 5rem;
    padding-bottom: 2.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 100px;
    padding: 0.4rem 1rem;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.9);
    font-weight: 500;
    margin-bottom: 1.5rem;
    letter-spacing: 0.01em;
  }

  .hero-title {
    color: #fff;
    font-size: clamp(1.8rem, 3.5vw, 2.7rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    text-align: left;
  }
  .hero-title-accent { color: #7EC8F0; }

  .hero-subtitle {
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.75;
    max-width: 620px;
    margin: 0 0 2rem;
    text-align: left;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-platforms {
    position: relative;
    z-index: 1;
    padding-bottom: 2.5rem;
  }

  /* ── Platforms carousel inside hero ── */
  .hero-platforms {
    position: relative;
    z-index: 1;
    padding-bottom: 3.5rem;
    padding-top: 0.5rem;
  }

  .platforms-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 1rem;
  }

  .pc-outer { display: flex; align-items: center; gap: 0.75rem; }
  .pc-viewport { overflow: hidden; flex: 1; }
  .platforms-grid {
    display: flex;
    gap: 1.25rem;
    transition: transform 0.45s cubic-bezier(0.22,1,0.36,1);
    will-change: transform;
  }

  .platform-card {
    flex: 0 0 calc((100% - 2.5rem) / 3);
    min-width: 0;
    display: flex;
    flex-direction: column;
    border-radius: 14px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    overflow: hidden;
    backdrop-filter: blur(6px);
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .platform-card:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.3);
    transform: translateY(-4px);
  }

  .platform-thumb {
    background: rgba(255,255,255,0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 2.5rem;
    min-height: 200px;
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }
  .platform-thumb img {
    width: 80%;
    height: 140px;
    object-fit: contain;
    object-position: center;
  }

  .platform-info { padding: 1rem 1.1rem 1.25rem; }
  .platform-info h3 { color: #fff; font-size: 0.95rem; margin-bottom: 0.35rem; }
  .platform-info p {
    color: rgba(255,255,255,0.65);
    font-size: 0.82rem;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
  }

  .pc-arrow {
    flex-shrink: 0; width: 38px; height: 38px; border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.1);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    backdrop-filter: blur(4px);
  }
  .pc-arrow:hover { background: rgba(255,255,255,0.25); border-color: rgba(255,255,255,0.6); }
  .pc-arrow:disabled { opacity: 0.25; pointer-events: none; }

  .pc-dots { display: flex; gap: 6px; justify-content: center; margin-top: 1rem; }
  .pc-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: rgba(255,255,255,0.3);
    border: none; cursor: pointer; padding: 0;
    transition: background 0.25s, transform 0.25s;
  }
  .pc-dot.active { background: #fff; transform: scale(1.3); }

  @media (max-width: 900px) {
    .platform-card { flex: 0 0 calc((100% - 1.25rem) / 2); }
  }
  @media (max-width: 768px) {
    .hero-top { padding-top: 3.5rem; padding-bottom: 2rem; }
    .hero-title { font-size: clamp(1.5rem, 6vw, 2rem); }
    .hero-subtitle { font-size: 0.92rem; max-width: 100%; }
    .hero-badge { font-size: 0.72rem; padding: 0.35rem 0.8rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
    .hero-cta { flex-direction: column; gap: 0.75rem; }
    .hero-cta .btn { width: 100%; text-align: center; }

    /* Carousel mobile : 1 carte visible, scroll natif */
    .pc-outer { gap: 0; overflow: hidden; }
    .pc-arrow { display: none; }
    .pc-viewport { overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .pc-viewport::-webkit-scrollbar { display: none; }
    .platforms-grid { gap: 0.75rem; }
    .platform-card { flex: 0 0 calc(100vw - 2.5rem); scroll-snap-align: start; }
    .platform-thumb { min-height: 160px; padding: 1.5rem 2rem; }
    .platform-info { padding: 0.85rem 1rem 1rem; }
    .platform-info h3 { font-size: 0.9rem; }
    .platform-info p { font-size: 0.8rem; -webkit-line-clamp: 2; }
  }
  @media (max-width: 480px) {
    .hero-top { padding-top: 3rem; }
    .hero-title { font-size: clamp(1.35rem, 7vw, 1.75rem); }
    .hero-badge { display: none; }
  }
</style>

<script is:inline src="/scripts/reveal.js"></script>
<script is:inline>
(function() {
  var grid = document.getElementById('platformsGrid');
  var prev = document.getElementById('pcPrev');
  var next = document.getElementById('pcNext');
  var dotsEl = document.getElementById('pcDots');
  if (!grid || !prev || !next || !dotsEl) return;

  var cards = grid.querySelectorAll('.platform-card');
  var total = cards.length;

  function getVisible() {
    return window.innerWidth <= 768 ? 1 : window.innerWidth <= 900 ? 2 : 3;
  }

  var visible = getVisible();
  var maxIndex = Math.max(0, total - visible);
  var idx = 0;

  for (var i = 0; i <= maxIndex; i++) {
    var d = document.createElement('button');
    d.className = 'pc-dot' + (i === 0 ? ' active' : '');
    d.setAttribute('aria-label', 'Page ' + (i + 1));
    d.dataset.i = String(i);
    dotsEl.appendChild(d);
  }

  function update() {
    if (!cards[0]) return;
    var cardW = cards[0].getBoundingClientRect().width;
    grid.style.transform = 'translateX(-' + (idx * (cardW + 20)) + 'px)';
    prev.disabled = idx === 0;
    next.disabled = idx >= maxIndex;
    dotsEl.querySelectorAll('.pc-dot').forEach(function(d, i) {
      d.classList.toggle('active', i === idx);
    });
  }

  prev.addEventListener('click', function() { if (idx > 0) { idx--; update(); } });
  next.addEventListener('click', function() { if (idx < maxIndex) { idx++; update(); } });
  dotsEl.addEventListener('click', function(e) {
    var d = e.target.closest('.pc-dot');
    if (d) { idx = +d.dataset.i; update(); }
  });
  window.addEventListener('resize', function() {
    visible = getVisible();
    maxIndex = Math.max(0, total - visible);
    idx = Math.min(idx, maxIndex);
    update();
  });

  update();
})();
</script>
