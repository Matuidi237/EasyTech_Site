---
import type { Lang } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const f = t.contact.form;

const allCountries = [
  { iso: "za", abbr: "ZAF", name: lang==="fr"?"Afrique du Sud":"South Africa",            code:"+27",  ph:"XX XXX XXXX",   group:"africa" },
  { iso: "dz", abbr: "DZA", name: lang==="fr"?"Algérie":"Algeria",                        code:"+213", ph:"XXX XX XX XX",  group:"africa" },
  { iso: "ao", abbr: "AGO", name: "Angola",                                                code:"+244", ph:"XXX XXX XXX",   group:"africa" },
  { iso: "bj", abbr: "BEN", name: lang==="fr"?"Bénin":"Benin",                            code:"+229", ph:"XX XX XX XX",   group:"africa" },
  { iso: "bw", abbr: "BWA", name: "Botswana",                                              code:"+267", ph:"XX XXX XXX",    group:"africa" },
  { iso: "bf", abbr: "BFA", name: "Burkina Faso",                                          code:"+226", ph:"XX XX XX XX",   group:"africa" },
  { iso: "bi", abbr: "BDI", name: "Burundi",                                               code:"+257", ph:"XX XX XX XX",   group:"africa" },
  { iso: "cm", abbr: "CMR", name: lang==="fr"?"Cameroun":"Cameroon",                       code:"+237", ph:"6XX XXX XXX",   group:"africa" },
  { iso: "cv", abbr: "CPV", name: lang==="fr"?"Cap-Vert":"Cape Verde",                    code:"+238", ph:"XXX XX XX",     group:"africa" },
  { iso: "cf", abbr: "CAF", name: lang==="fr"?"Centrafrique":"Central African Republic",   code:"+236", ph:"XX XX XX XX",   group:"africa" },
  { iso: "km", abbr: "COM", name: lang==="fr"?"Comores":"Comoros",                        code:"+269", ph:"XXX XX XX",     group:"africa" },
  { iso: "cg", abbr: "COG", name: lang==="fr"?"Congo (Brazzaville)":"Congo (Brazzaville)",code:"+242", ph:"XX XXX XXXX",   group:"africa" },
  { iso: "cd", abbr: "COD", name: lang==="fr"?"Congo (Kinshasa)":"Congo (Kinshasa)",       code:"+243", ph:"XXX XXX XXX",   group:"africa" },
  { iso: "ci", abbr: "CIV", name: lang==="fr"?"Côte d'Ivoire":"Ivory Coast",              code:"+225", ph:"XX XX XX XX XX",group:"africa" },
  { iso: "dj", abbr: "DJI", name: "Djibouti",                                              code:"+253", ph:"XX XX XX XX",   group:"africa" },
  { iso: "eg", abbr: "EGY", name: lang==="fr"?"Égypte":"Egypt",                           code:"+20",  ph:"1XX XXX XXXX",  group:"africa" },
  { iso: "er", abbr: "ERI", name: lang==="fr"?"Érythrée":"Eritrea",                       code:"+291", ph:"X XXX XXX",     group:"africa" },
  { iso: "et", abbr: "ETH", name: lang==="fr"?"Éthiopie":"Ethiopia",                      code:"+251", ph:"9X XXX XXXX",   group:"africa" },
  { iso: "ga", abbr: "GAB", name: "Gabon",                                                 code:"+241", ph:"X XX XX XX",    group:"africa" },
  { iso: "gm", abbr: "GMB", name: lang==="fr"?"Gambie":"Gambia",                          code:"+220", ph:"XXX XXXX",      group:"africa" },
  { iso: "gh", abbr: "GHA", name: "Ghana",                                                 code:"+233", ph:"XX XXX XXXX",   group:"africa" },
  { iso: "gn", abbr: "GIN", name: lang==="fr"?"Guinée":"Guinea",                          code:"+224", ph:"XXX XX XX XX",  group:"africa" },
  { iso: "gq", abbr: "GNQ", name: lang==="fr"?"Guinée équatoriale":"Equatorial Guinea",   code:"+240", ph:"XXX XXX XXX",   group:"africa" },
  { iso: "gw", abbr: "GNB", name: lang==="fr"?"Guinée-Bissau":"Guinea-Bissau",            code:"+245", ph:"XXX XXXX",      group:"africa" },
  { iso: "ke", abbr: "KEN", name: "Kenya",                                                 code:"+254", ph:"7XX XXX XXX",   group:"africa" },
  { iso: "ls", abbr: "LSO", name: "Lesotho",                                               code:"+266", ph:"XX XXX XXX",    group:"africa" },
  { iso: "lr", abbr: "LBR", name: "Liberia",                                               code:"+231", ph:"XXX XXX XXX",   group:"africa" },
  { iso: "ly", abbr: "LBY", name: lang==="fr"?"Libye":"Libya",                            code:"+218", ph:"91 XXX XXXX",   group:"africa" },
  { iso: "mg", abbr: "MDG", name: "Madagascar",                                             code:"+261", ph:"XX XX XXX XX",  group:"africa" },
  { iso: "mw", abbr: "MWI", name: "Malawi",                                                code:"+265", ph:"X XXX XXXX",    group:"africa" },
  { iso: "ml", abbr: "MLI", name: "Mali",                                                  code:"+223", ph:"XX XX XX XX",   group:"africa" },
  { iso: "ma", abbr: "MAR", name: lang==="fr"?"Maroc":"Morocco",                          code:"+212", ph:"6XX XXX XXX",   group:"africa" },
  { iso: "mu", abbr: "MUS", name: lang==="fr"?"Maurice":"Mauritius",                      code:"+230", ph:"X XXX XXXX",    group:"africa" },
  { iso: "mr", abbr: "MRT", name: lang==="fr"?"Mauritanie":"Mauritania",                  code:"+222", ph:"XX XX XX XX",   group:"africa" },
  { iso: "mz", abbr: "MOZ", name: "Mozambique",                                             code:"+258", ph:"8X XXX XXXX",   group:"africa" },
  { iso: "na", abbr: "NAM", name: lang==="fr"?"Namibie":"Namibia",                        code:"+264", ph:"XX XXX XXXX",   group:"africa" },
  { iso: "ne", abbr: "NER", name: "Niger",                                                 code:"+227", ph:"XX XX XX XX",   group:"africa" },
  { iso: "ng", abbr: "NGA", name: "Nigeria",                                               code:"+234", ph:"XXX XXX XXXX",  group:"africa" },
  { iso: "ug", abbr: "UGA", name: lang==="fr"?"Ouganda":"Uganda",                         code:"+256", ph:"7XX XXX XXX",   group:"africa" },
  { iso: "rw", abbr: "RWA", name: "Rwanda",                                                code:"+250", ph:"7XX XXX XXX",   group:"africa" },
  { iso: "st", abbr: "STP", name: lang==="fr"?"São Tomé-et-Príncipe":"São Tomé & Príncipe",code:"+239",ph:"XXX XXXX",      group:"africa" },
  { iso: "sn", abbr: "SEN", name: lang==="fr"?"Sénégal":"Senegal",                        code:"+221", ph:"7X XXX XX XX",  group:"africa" },
  { iso: "sc", abbr: "SYC", name: "Seychelles",                                             code:"+248", ph:"X XXX XXX",     group:"africa" },
  { iso: "sl", abbr: "SLE", name: "Sierra Leone",                                           code:"+232", ph:"XX XXX XXX",    group:"africa" },
  { iso: "so", abbr: "SOM", name: lang==="fr"?"Somalie":"Somalia",                        code:"+252", ph:"XX XXX XXX",    group:"africa" },
  { iso: "sd", abbr: "SDN", name: lang==="fr"?"Soudan":"Sudan",                           code:"+249", ph:"XX XXX XXXX",   group:"africa" },
  { iso: "ss", abbr: "SSD", name: lang==="fr"?"Soudan du Sud":"South Sudan",              code:"+211", ph:"XX XXX XXXX",   group:"africa" },
  { iso: "tz", abbr: "TZA", name: lang==="fr"?"Tanzanie":"Tanzania",                      code:"+255", ph:"7XX XXX XXX",   group:"africa" },
  { iso: "td", abbr: "TCD", name: lang==="fr"?"Tchad":"Chad",                             code:"+235", ph:"XX XX XX XX",   group:"africa" },
  { iso: "tg", abbr: "TGO", name: "Togo",                                                  code:"+228", ph:"XX XX XX XX",   group:"africa" },
  { iso: "tn", abbr: "TUN", name: lang==="fr"?"Tunisie":"Tunisia",                        code:"+216", ph:"XX XXX XXX",    group:"africa" },
  { iso: "zm", abbr: "ZMB", name: lang==="fr"?"Zambie":"Zambia",                          code:"+260", ph:"XX XXX XXXX",   group:"africa" },
  { iso: "zw", abbr: "ZWE", name: "Zimbabwe",                                              code:"+263", ph:"7X XXX XXXX",   group:"africa" },
  { iso: "de", abbr: "DEU", name: lang==="fr"?"Allemagne":"Germany",                      code:"+49",  ph:"1XX XXXXXXXX",  group:"intl"   },
  { iso: "be", abbr: "BEL", name: lang==="fr"?"Belgique":"Belgium",                       code:"+32",  ph:"4XX XX XX XX",  group:"intl"   },
  { iso: "ca", abbr: "CAN", name: "Canada",                                                code:"+1",   ph:"XXX XXX XXXX",  group:"intl"   },
  { iso: "fr", abbr: "FRA", name: "France",                                                code:"+33",  ph:"6 XX XX XX XX", group:"intl"   },
  { iso: "gb", abbr: "GBR", name: lang==="fr"?"Royaume-Uni":"United Kingdom",             code:"+44",  ph:"7XXX XXXXXX",   group:"intl"   },
  { iso: "ch", abbr: "CHE", name: lang==="fr"?"Suisse":"Switzerland",                     code:"+41",  ph:"XX XXX XXXX",   group:"intl"   },
  { iso: "us", abbr: "USA", name: lang==="fr"?"États-Unis":"United States",               code:"+1",   ph:"XXX XXX XXXX",  group:"intl"   },
];

const defaultIso = "cm";
const defaultCode = "+237";
const defaultName = lang === "fr" ? "Cameroun" : "Cameroon";

const successMsg = lang === "fr"
  ? { title: "Demande envoyée !", body: "Notre équipe vous contactera sous 24 à 48 heures ouvrées. À très bientôt !", close: "Fermer" }
  : { title: "Request sent!", body: "Our team will contact you within 24 to 48 business hours. Talk soon!", close: "Close" };
---

<section id="contact" class="contact" aria-labelledby="contact-title">
  <div class="circle-deco contact-circle-1" aria-hidden="true"></div>
  <div class="circle-deco circle-delay circle-fill contact-circle-2" aria-hidden="true"></div>
  <div class="container">
    <div class="contact-intro reveal">
      <p class="eyebrow">{t.contact.eyebrow ?? "Contact"}</p>
      <h1 id="contact-title">{t.contact.title}</h1>
      <p class="contact-subtitle">{t.contact.subtitle}</p>
    </div>

    <form
      id="demo-form"
      class="contact-form reveal"
      method="post"
      action="/api/contact"
      novalidate
      data-lang={lang}
    >
      <div class="form-row">
        <div class="form-field">
          <label for="name">{f.name} *</label>
          <input type="text" id="name" name="name" autocomplete="name" />
          <span class="field-error" id="name-error" role="alert"></span>
        </div>
        <div class="form-field">
          <label for="org">{f.organization} *</label>
          <input type="text" id="org" name="organization" autocomplete="organization" />
          <span class="field-error" id="org-error" role="alert"></span>
        </div>
      </div>

      <div class="form-row">
        <div class="form-field">
          <label for="email">{f.email} *</label>
          <input type="email" id="email" name="email" autocomplete="email" />
          <span class="field-error" id="email-error" role="alert"></span>
        </div>
        <div class="form-field">
          <label for="phone">{f.phone} *</label>
          <div class="phone-row">
            <div class="phone-country">
              <img
                id="country-flag-img"
                src={`https://flagcdn.com/w20/${defaultIso}.png`}
                srcset={`https://flagcdn.com/w40/${defaultIso}.png 2x`}
                width="20" height="15"
                alt={defaultName}
              />
              <span id="country-abbr" aria-hidden="true">CMR +237</span>
              <select
                id="country-code"
                name="countryCode"
                class="country-select"
                aria-label={lang === "fr" ? "Indicatif pays" : "Country code"}
              >
                <optgroup label={lang === "fr" ? "── Afrique ──" : "── Africa ──"}>
                  {allCountries.filter(c => c.group === "africa").map(c => (
                    <option
                      value={c.code}
                      data-iso={c.iso}
                      data-abbr={c.abbr}
                      data-ph={c.ph}
                      selected={c.iso === defaultIso ? true : undefined}
                    >
                      {c.name} ({c.code})
                    </option>
                  ))}
                </optgroup>
                <optgroup label={lang === "fr" ? "── International ──" : "── International ──"}>
                  {allCountries.filter(c => c.group === "intl").map(c => (
                    <option value={c.code} data-iso={c.iso} data-abbr={c.abbr} data-ph={c.ph}>
                      {c.name} ({c.code})
                    </option>
                  ))}
                </optgroup>
              </select>
            </div>
            <input type="tel" id="phone" name="phone" autocomplete="tel"
              placeholder="6XX XXX XXX" class="phone-input" />
          </div>
          <span class="field-error" id="phone-error" role="alert"></span>
        </div>
      </div>

      <div class="form-field">
        <label for="org-type">{f.orgType} *</label>
        <select id="org-type" name="orgType">
          <option value="">{lang === "fr" ? "-- Sélectionnez --" : "-- Select --"}</option>
          {f.orgTypeOptions.map((opt: string) => <option value={opt}>{opt}</option>)}
        </select>
        <span class="field-error" id="orgtype-error" role="alert"></span>
      </div>

      <div class="form-field">
        <label for="need">{f.need} *</label>
        <textarea id="need" name="need" rows="5" placeholder={f.needPlaceholder}></textarea>
        <span class="field-error" id="need-error" role="alert"></span>
      </div>

      <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <input type="hidden" name="loadedAt" id="loadedAt" />

      <div class="form-submit-row">
        <button type="submit" class="btn btn-primary">{f.submit}</button>
        <span class="form-note">{t.contact.formNote ?? ""}</span>
      </div>
      <p class="form-feedback" id="form-feedback" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<!-- Success modal -->
<div id="success-modal" class="modal-overlay" hidden aria-modal="true" role="dialog">
  <div class="modal-card">
    <div class="modal-icon" aria-hidden="true">
      <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="26" cy="26" r="25" stroke="currentColor" stroke-width="2"/>
        <path d="M14 26.5L22 34.5L38 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h3>{successMsg.title}</h3>
    <p>{successMsg.body}</p>
    <button class="btn btn-primary modal-close-btn" id="modal-close">{successMsg.close}</button>
  </div>
</div>

<style>
  .contact { position: relative; overflow: hidden; padding-top: 1rem; }
  .contact-circle-1 { top: -60px; right: 10%; width: 220px; height: 220px; }
  .contact-circle-2 { bottom: 5%; left: -70px; width: 240px; height: 240px; }
  .contact .container { position: relative; z-index: 1; }

  .contact-intro { max-width: 640px; margin: 0 auto 2.5rem; text-align: center; }
  .contact-subtitle { margin-top: 0.75rem; font-size: 1.1rem; }

  .contact-form {
    max-width: 700px;
    margin: 0 auto;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 30px 60px rgba(2, 33, 121, 0.08);
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .form-field { margin-bottom: 1.25rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .form-field label { font-weight: 500; font-size: 0.9rem; }
  .form-field input, .form-field select, .form-field textarea {
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .form-field input:focus, .form-field select:focus, .form-field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(164, 37, 147, 0.15);
  }

  /* Phone row */
  .phone-row { display: flex; min-width: 0; }

  .phone-country {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0 0.6rem 0 0.75rem;
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    background: var(--color-bg-secondary);
    flex-shrink: 0;
    white-space: nowrap;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .phone-country img {
    width: 20px;
    height: 15px;
    object-fit: cover;
    border-radius: 2px;
    flex-shrink: 0;
    display: block;
    pointer-events: none;
  }
  #country-abbr {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-text);
    pointer-events: none;
    letter-spacing: 0.01em;
  }
  .country-select {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    border: none;
    background: transparent;
    font-size: 1rem;
  }
  .phone-country:focus-within {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(164, 37, 147, 0.15);
    z-index: 1;
  }

  .phone-input {
    flex: 1;
    min-width: 0;
    border-radius: 0 8px 8px 0 !important;
    border-left: none !important;
  }
  .phone-input:focus {
    border-color: var(--color-accent) !important;
    box-shadow: 0 0 0 3px rgba(164, 37, 147, 0.15) !important;
    z-index: 1;
    position: relative;
  }

  @media (max-width: 560px) {
    .phone-row { flex-direction: column; }
    .phone-country { border-right: 1px solid var(--color-border); border-radius: 8px; border-bottom: none; border-radius: 8px 8px 0 0; max-width: 100%; }
    .phone-input { border-left: 1px solid var(--color-border) !important; border-radius: 0 0 8px 8px !important; }
  }

  .honeypot { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .form-submit-row { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .contact-form .btn-primary { padding: 0.85rem 2rem; }
  .form-note { font-size: 0.85rem; color: var(--color-text-secondary); }

  .field-error {
    display: none;
    font-size: 0.8rem;
    color: #C0392B;
    margin-top: 0.2rem;
  }
  .field-error.visible { display: block; }
  .form-field input.invalid,
  .form-field select.invalid,
  .form-field textarea.invalid,
  .phone-input.invalid {
    border-color: #C0392B !important;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.15) !important;
  }

  .form-feedback {
    margin-top: 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    min-height: 1.2em;
  }
  .form-feedback.error { color: #C0392B; }

  @media (max-width: 700px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-form { padding: 1.75rem 1.5rem; }
  }

  /* Success modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(11, 14, 46, 0.6);
    backdrop-filter: blur(4px);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: modal-fade-in 0.25s ease;
  }
  .modal-overlay[hidden] { display: none; }

  @keyframes modal-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .modal-card {
    background: var(--color-card-bg);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    max-width: 420px;
    width: 100%;
    text-align: center;
    box-shadow: 0 40px 80px rgba(2, 33, 121, 0.2);
    animation: modal-slide-up 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes modal-slide-up {
    from { transform: translateY(32px) scale(0.96); opacity: 0; }
    to   { transform: translateY(0) scale(1);      opacity: 1; }
  }

  .modal-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.25rem;
    color: var(--color-accent);
  }
  .modal-icon svg { width: 100%; height: 100%; }

  .modal-card h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }
  .modal-card p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1.75rem;
  }
</style>

<script>
  // ── Init ──────────────────────────────────────────────────────────────────
  document.getElementById("loadedAt")?.setAttribute("value", String(Date.now()));

  const form         = document.getElementById("demo-form") as HTMLFormElement | null;
  const countrySelect= document.getElementById("country-code") as HTMLSelectElement | null;
  const flagImg      = document.getElementById("country-flag-img") as HTMLImageElement | null;
  const abbrSpan     = document.getElementById("country-abbr");
  const phoneInput   = document.getElementById("phone") as HTMLInputElement | null;
  const modal        = document.getElementById("success-modal") as HTMLElement | null;
  const modalClose   = document.getElementById("modal-close");
  const formFeedback = document.getElementById("form-feedback");
  const lang         = form?.dataset.lang ?? "fr";
  const isFr        = lang === "fr";

  // ── Country selector ──────────────────────────────────────────────────────
  function updateCountry() {
    if (!countrySelect) return;
    const sel = countrySelect.options[countrySelect.selectedIndex] as HTMLOptionElement & { dataset: DOMStringMap };
    const iso  = sel.dataset.iso  ?? "cm";
    const abbr = sel.dataset.abbr ?? iso.toUpperCase();
    const ph   = sel.dataset.ph   ?? "XXXXXXXXX";
    if (flagImg) {
      flagImg.src    = `https://flagcdn.com/w20/${iso}.png`;
      flagImg.srcset = `https://flagcdn.com/w40/${iso}.png 2x`;
      flagImg.alt    = sel.text.split("(")[0].trim();
    }
    if (abbrSpan) abbrSpan.textContent = `${abbr} ${countrySelect.value}`;
    if (phoneInput) phoneInput.placeholder = ph;
  }

  updateCountry();
  countrySelect?.addEventListener("change", updateCountry);

  // ── Validation helpers ────────────────────────────────────────────────────
  function setError(inputId: string, errorId: string, message: string) {
    const input = document.getElementById(inputId);
    const errEl = document.getElementById(errorId);
    input?.classList.add("invalid");
    if (errEl) { errEl.textContent = message; errEl.classList.add("visible"); }
  }

  function clearErrors() {
    form?.querySelectorAll(".invalid").forEach(el => el.classList.remove("invalid"));
    form?.querySelectorAll(".field-error").forEach(el => {
      el.textContent = "";
      el.classList.remove("visible");
    });
    if (formFeedback) { formFeedback.textContent = ""; formFeedback.className = "form-feedback"; }
  }

  function validate(): boolean {
    clearErrors();
    let ok = true;

    const name    = (document.getElementById("name")     as HTMLInputElement)?.value.trim() ?? "";
    const org     = (document.getElementById("org")      as HTMLInputElement)?.value.trim() ?? "";
    const email   = (document.getElementById("email")    as HTMLInputElement)?.value.trim() ?? "";
    const orgType = (document.getElementById("org-type") as HTMLSelectElement)?.value ?? "";
    const need    = (document.getElementById("need")     as HTMLTextAreaElement)?.value.trim() ?? "";
    const rawPhone= (phoneInput?.value ?? "").trim().replace(/^0+/, "").replace(/[\s\-]/g, "");

    if (name.length < 2) {
      setError("name", "name-error", isFr ? "Nom requis (2 caractères min.)" : "Name required (min. 2 chars)");
      ok = false;
    }
    if (org.length < 2) {
      setError("org", "org-error", isFr ? "Organisation requise (2 caractères min.)" : "Organization required (min. 2 chars)");
      ok = false;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      setError("email", "email-error", isFr ? "Adresse email invalide" : "Invalid email address");
      ok = false;
    }
    if (rawPhone.length < 5 || !/^\d+$/.test(rawPhone)) {
      setError("phone", "phone-error", isFr ? "Numéro requis (chiffres uniquement, sans indicatif)" : "Number required (digits only, without country code)");
      ok = false;
    }
    if (!orgType) {
      setError("org-type", "orgtype-error", isFr ? "Veuillez sélectionner un type d'organisation" : "Please select an organization type");
      ok = false;
    }
    if (need.length < 10) {
      setError("need", "need-error", isFr ? "Décrivez votre besoin (10 caractères min.)" : "Describe your need (min. 10 chars)");
      ok = false;
    }

    return ok;
  }

  // ── Form submit ───────────────────────────────────────────────────────────
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !phoneInput || !countrySelect) return;

    if (!validate()) return;

    // Combine indicatif + numéro (rawPhone is digits only)
    const rawPhone = phoneInput.value.trim().replace(/^0+/, "").replace(/[\s\-]/g, "");
    phoneInput.value = `${countrySelect.value} ${rawPhone}`;

    const formData = new FormData(form);
    const submitBtn = form.querySelector("button[type=submit]") as HTMLButtonElement | null;

    if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = "0.7"; }

    try {
      const res = await fetch(form.action, { method: "POST", body: formData });

      if (res.ok) {
        form.reset();
        updateCountry();
        if (modal) { modal.hidden = false; document.body.style.overflow = "hidden"; }
      } else {
        const status = res.status;
        const msg = status === 429
          ? (isFr ? "Trop de tentatives. Réessayez dans quelques minutes." : "Too many attempts. Please try again in a few minutes.")
          : (isFr ? "Une erreur est survenue. Réessayez ou écrivez-nous à contact@thinktech-solutions.com." : "An error occurred. Please retry or email us at contact@thinktech-solutions.com.");
        if (formFeedback) { formFeedback.textContent = msg; formFeedback.className = "form-feedback error"; }
        // Restore phone for resubmission
        phoneInput.value = rawPhone;
      }
    } catch {
      if (formFeedback) {
        formFeedback.textContent = isFr
          ? "Connexion impossible. Vérifiez votre connexion internet."
          : "Connection failed. Check your internet connection.";
        formFeedback.className = "form-feedback error";
      }
      phoneInput.value = rawPhone;
    } finally {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = ""; }
    }
  });

  // Clear field error on input
  form?.querySelectorAll("input, select, textarea").forEach(el => {
    el.addEventListener("input", () => {
      const id = (el as HTMLElement).id;
      el.classList.remove("invalid");
      const errEl = form.querySelector(`#${id}-error, #${id.replace("-", "")}type-error`);
      if (errEl) { errEl.textContent = ""; errEl.classList.remove("visible"); }
      if (formFeedback) { formFeedback.textContent = ""; formFeedback.className = "form-feedback"; }
    });
  });

  // ── Modal ─────────────────────────────────────────────────────────────────
  function closeModal() {
    if (modal) { modal.hidden = true; document.body.style.overflow = ""; }
  }
  modalClose?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape" && modal && !modal.hidden) closeModal(); });
</script>
