---
import type { Lang } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const f = t.contact.form;
---

<section id="contact" class="contact" aria-labelledby="contact-title">
  <div class="container">
    <h2 id="contact-title">{t.contact.title}</h2>
    <p class="contact-subtitle">{t.contact.subtitle}</p>

    <div class="contact-grid">
      <address class="contact-info">
        <a href="mailto:contact@thinktech-solutions.com">contact@thinktech-solutions.com</a>
        <a href="tel:+237689357969">+237 689 35 79 69</a>
        <span>Douala, Cameroun</span>
      </address>

      <form id="demo-form" method="post" action="/api/contact" novalidate>
        <div class="form-field">
          <label for="name">{f.name} *</label>
          <input type="text" id="name" name="name" required autocomplete="name" minlength="2" />
        </div>
        <div class="form-field">
          <label for="org">{f.organization} *</label>
          <input type="text" id="org" name="organization" required autocomplete="organization" minlength="2" />
        </div>
        <div class="form-field">
          <label for="email">{f.email} *</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div class="form-field">
          <label for="phone">{f.phone} *</label>
          <input type="tel" id="phone" name="phone" required autocomplete="tel" pattern="^[+]?[0-9\s-]{8,15}$" />
        </div>
        <div class="form-field">
          <label for="org-type">{f.orgType} *</label>
          <select id="org-type" name="orgType" required>
            <option value=""></option>
            {f.orgTypeOptions.map((opt: string) => <option value={opt}>{opt}</option>)}
          </select>
        </div>
        <div class="form-field">
          <label for="need">{f.need} *</label>
          <textarea id="need" name="need" required rows="4" minlength="10" placeholder={f.needPlaceholder}></textarea>
        </div>

        <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <input type="hidden" name="loadedAt" id="loadedAt" />

        <button type="submit" class="btn btn-primary">{f.submit}</button>
        <p class="form-feedback" role="status" aria-live="polite" data-success={f.success} data-error={f.error}></p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-subtitle { max-width: 700px; margin-bottom: 2.5rem; }
  .contact-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 2.5rem; }
  .contact-info { display: flex; flex-direction: column; gap: 0.75rem; }
  .form-field { margin-bottom: 1.1rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .form-field label { font-weight: 500; font-size: 0.9rem; }
  .form-field input, .form-field select, .form-field textarea {
    padding: 0.7rem; border: 1px solid var(--color-border); border-radius: 8px;
    background: var(--color-card-bg); color: var(--color-text); font-family: inherit;
  }
  .honeypot { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .form-feedback { margin-top: 1rem; font-weight: 500; }
  .form-feedback.success { color: var(--color-success); }
  .form-feedback.error { color: #C0392B; }

  @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; } }
</style>

<script>
  document.getElementById("loadedAt")?.setAttribute("value", String(Date.now()));
</script>
<script is:inline src="/scripts/form-validation.js"></script>
