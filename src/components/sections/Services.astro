---
import type { Lang } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const icons: Record<string, string> = {
  rocket:
    '<path d="M12 2c2.5 2 4 5.5 4 9 0 2-1 4-2 5l-2 2-2-2c-1-1-2-3-2-5 0-3.5 1.5-7 4-9Z"/><circle cx="12" cy="10" r="1.6"/><path d="M9 16l-2.5 1.5L7 14"/><path d="M15 16l2.5 1.5L17 14"/>',
  server:
    '<rect x="3.5" y="4" width="17" height="6" rx="1.5"/><rect x="3.5" y="14" width="17" height="6" rx="1.5"/><circle cx="7" cy="7" r="0.8" fill="currentColor" stroke="none"/><circle cx="7" cy="17" r="0.8" fill="currentColor" stroke="none"/>',
  palette:
    '<path d="M12 3a9 9 0 1 0 0 18c1.2 0 1.8-.7 1.8-1.6 0-.5-.2-.9-.5-1.2-.3-.3-.5-.7-.5-1.2 0-.9.7-1.6 1.6-1.6H16a5 5 0 0 0 5-5c0-4.1-4-7.4-9-7.4Z"/><circle cx="7.5" cy="10.5" r="1" fill="currentColor" stroke="none"/><circle cx="9.5" cy="7" r="1" fill="currentColor" stroke="none"/><circle cx="14.5" cy="7" r="1" fill="currentColor" stroke="none"/>',
  plug:
    '<path d="M9 7V3M15 7V3"/><path d="M7 7h10v4a5 5 0 0 1-10 0V7Z"/><path d="M12 16v3"/><path d="M9 21h6"/>',
  "graduation-cap":
    '<path d="M12 4 2 9l10 5 10-5-10-5Z"/><path d="M6 11.5V17c0 1.5 2.7 3 6 3s6-1.5 6-3v-5.5"/><path d="M22 9v6"/>',
  headset:
    '<path d="M4 13a8 8 0 0 1 16 0"/><rect x="3" y="13" width="4" height="6" rx="1.5"/><rect x="17" y="13" width="4" height="6" rx="1.5"/><path d="M20 19a4 4 0 0 1-4 3h-2"/>',
  "check-circle":
    '<circle cx="12" cy="12" r="9"/><path d="M8 12.5l3 3 5-5.5"/>',
  smartphone:
    '<rect x="6" y="2" width="12" height="20" rx="3"/><circle cx="12" cy="17.5" r="0.8" fill="currentColor" stroke="none"/>',
  shield:
    '<path d="M12 3 4 7v5c0 4.4 3.4 8.5 8 9.5 4.6-1 8-5.1 8-9.5V7l-8-4Z"/>',
  layers:
    '<polygon points="12 2 2 7 12 12 22 7"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
};
---

<section class="services-hero" aria-labelledby="services-hero-title">
  <div class="services-hero-bg" aria-hidden="true"></div>
  <div class="container services-hero-inner reveal">
    <p class="eyebrow eyebrow-light">{t.services.eyebrow ?? "Notre expertise"}</p>
    <h1 id="services-hero-title">{t.services.title}</h1>
    <p class="services-hero-subtitle">{t.services.subtitle}</p>
    <a href={`/${lang}/contact`} class="btn-hero">
      {t.services.cta}
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 10h12M11 5l5 5-5 5"/></svg>
    </a>
  </div>
</section>

<section id="services" class="services" aria-labelledby="services-title">
  <div class="circle-deco services-circle-1" aria-hidden="true"></div>
  <div class="container">
    <ul class="services-grid">
      {t.services.cards.map((c: any, i: number) => (
        <li class="service-card reveal" style={`transition-delay:${(i % 3) * 0.08}s`}>
          <span class="service-icon" aria-hidden="true" set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${icons[c.icon] ?? ""}</svg>`} />
          <span class="service-num">{String(i + 1).padStart(2, "0")}</span>
          <h3>{c.title}</h3>
          <p class="benefit">{c.benefit}</p>
          <ul>
            {c.points.map((p: string) => <li>{p}</li>)}
          </ul>
        </li>
      ))}
    </ul>

    <div class="why-us">
      <div class="why-header reveal">
        <h2>{t.services.whyTitle}</h2>
        <p class="why-subtitle">{t.services.whySubtitle}</p>
      </div>

      <!-- Carousel -->
      <div class="why-carousel" role="region" aria-label={t.services.whyTitle}>
        <button class="carousel-btn carousel-prev" aria-label="Précédent">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <div class="carousel-viewport">
          <ul class="carousel-track">
            {t.services.why.map((w: any, i: number) => (
              <li class="why-card" data-index={i}>
                <div class="why-card-icon" aria-hidden="true" set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${icons[w.icon] ?? icons["check-circle"]}</svg>`} />
                <div class="why-card-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</div>
                <h3>{w.title}</h3>
                <p>{w.text}</p>
              </li>
            ))}
          </ul>
        </div>
        <button class="carousel-btn carousel-next" aria-label="Suivant">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>

      <!-- Dots -->
      <div class="carousel-dots" role="tablist" aria-label="Navigation carrousel">
        {t.services.why.map((_: any, i: number) => (
          <button
            class="carousel-dot"
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            aria-label={`Carte ${i + 1}`}
            data-dot={i}
          />
        ))}
      </div>
    </div>

    <h3 class="process-title reveal">{t.services.processTitle}</h3>
    <ol class="process-steps">
      {t.services.process.map((s: any, i: number) => (
        <li class="reveal" style={`transition-delay:${i * 0.1}s`}>
          <span class="step-number">{i + 1}</span>
          <h4>{s.title}</h4>
          <p>{s.text}</p>
        </li>
      ))}
    </ol>

    <div class="services-cta reveal">
      <h3>{t.services.ctaTitle}</h3>
      <a href={`/${lang}/contact`} class="btn btn-primary">{t.services.cta}</a>
    </div>
  </div>
</section>

<style>
  /* ══════════════════════════════════════
     HERO
  ══════════════════════════════════════ */
  .services-hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 7rem 0 5rem;
    color: #fff;
  }
  .services-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/services/services-hero.jpg');
    background-size: cover;
    background-position: center top;
    z-index: 0;
  }
  .services-hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(2, 33, 121, 0.88) 0%,
      rgba(164, 37, 147, 0.60) 100%
    );
  }
  .services-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 640px;
    padding-left: 2rem;
  }
  .eyebrow-light {
    color: rgba(255, 255, 255, 0.75);
    border-color: rgba(255, 255, 255, 0.3);
  }
  .services-hero h1 {
    color: #fff;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.15;
    margin: 0.75rem 0 1.25rem;
  }
  .services-hero-subtitle {
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.7;
    margin-bottom: 2.25rem;
  }

  /* Hero CTA button */
  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.75rem;
    border-radius: 50px;
    background: #fff;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.22), 0 0 0 3px rgba(255,255,255,0.18);
    transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
    white-space: nowrap;
  }
  .btn-hero svg { width: 18px; height: 18px; transition: transform 0.22s ease; }
  .btn-hero:hover {
    background: #f5f5f5;
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.28), 0 0 0 3px rgba(255,255,255,0.25);
  }
  .btn-hero:hover svg { transform: translateX(4px); }

  /* Mobile hero */
  @media (max-width: 600px) {
    .services-hero {
      min-height: unset;
      padding: 5rem 0 4rem;
      align-items: flex-end;
    }
    .services-hero-bg { background-position: 70% center; }
    .services-hero-bg::after {
      background: linear-gradient(
        180deg,
        rgba(2, 33, 121, 0.55) 0%,
        rgba(2, 33, 121, 0.92) 60%,
        rgba(2, 33, 121, 0.98) 100%
      );
    }
    .services-hero-inner {
      max-width: 100%;
      padding-left: 0;
      text-align: left;
    }
  }

  /* ══════════════════════════════════════
     SERVICES GRID
  ══════════════════════════════════════ */
  .services { position: relative; overflow: hidden; padding-top: 1rem; }
  .services-circle-1 { top: 10%; right: -80px; width: 220px; height: 220px; }
  .services .container { position: relative; z-index: 1; }

  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; list-style: none; margin: 0 0 4rem; }
  .service-card {
    position: relative;
    padding: 2rem 1.75rem 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-card-bg);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }
  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 22px 40px rgba(2, 33, 121, 0.12);
    border-color: var(--color-accent);
  }
  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: var(--color-bg-secondary);
    color: var(--color-accent);
    margin-bottom: 1rem;
    transition: background 0.28s ease, color 0.28s ease, transform 0.28s ease;
  }
  .service-icon svg { width: 24px; height: 24px; }
  .service-card:hover .service-icon { background: var(--color-accent); color: #fff; transform: scale(1.08) rotate(-4deg); }
  .service-num { position: absolute; top: 1.75rem; right: 1.75rem; color: var(--color-text-secondary); font-size: 0.85rem; opacity: 0.5; }
  .service-card .benefit { font-weight: 500; color: var(--color-text); margin: 0.5rem 0; }
  .service-card ul { margin-top: 0.5rem; padding-left: 1.1rem; color: var(--color-text-secondary); font-size: 0.9rem; }
  .service-card ul li + li { margin-top: 0.2rem; }

  /* ══════════════════════════════════════
     WHY US — CAROUSEL
  ══════════════════════════════════════ */
  .why-us {
    margin-bottom: 4rem;
    padding: 4rem 0 3rem;
    background: linear-gradient(160deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
    border-radius: 20px;
    overflow: hidden;
  }
  .why-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 0 1.5rem;
  }
  .why-header h2 { margin-bottom: 1rem; }
  .why-subtitle {
    max-width: 640px;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* Carousel shell */
  .why-carousel {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1rem;
  }
  .carousel-viewport {
    flex: 1;
    overflow: hidden;
    border-radius: 16px;
    min-width: 0;
  }
  .carousel-track {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 1rem 0.25rem 1.5rem;
    gap: 1.25rem;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* Cards */
  .why-card {
    position: relative;
    flex: 0 0 calc(33.33% - 0.84rem);
    border-radius: 16px;
    padding: 2rem 1.75rem 2.5rem;
    background: var(--color-card-bg) padding-box, var(--color-border) border-box;
    border: 2px solid transparent;
    box-shadow: 0 4px 16px rgba(2, 33, 121, 0.06);
    opacity: 0.55;
    transform: scale(0.96);
    transition:
      transform 0.5s cubic-bezier(0.34, 1.4, 0.64, 1),
      opacity 0.45s ease,
      box-shadow 0.45s ease;
    cursor: pointer;
    user-select: none;
  }
  .why-card.active {
    opacity: 1;
    transform: scale(1.03);
    background:
      var(--color-card-bg) padding-box,
      linear-gradient(135deg, #A42593, #022179, #C94BB0) border-box;
    box-shadow:
      0 24px 56px rgba(164, 37, 147, 0.20),
      0 8px 20px rgba(2, 33, 121, 0.12);
  }

  /* Progress bar */
  .why-card::after {
    content: "";
    position: absolute;
    bottom: 0; left: 0;
    height: 3px;
    width: 100%;
    background: linear-gradient(90deg, #A42593, #022179);
    border-radius: 0 0 14px 14px;
    transform: scaleX(0);
    transform-origin: left;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .why-card.active::after {
    opacity: 1;
    animation: progress-run var(--why-duration, 3s) linear forwards;
  }
  @keyframes progress-run {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  .why-card-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: transform 0.3s ease;
  }
  .why-card.active .why-card-icon { transform: scale(1.1); }
  .why-card-icon svg { width: 22px; height: 22px; }

  .why-card-num {
    position: absolute;
    top: 1.4rem;
    right: 1.5rem;
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--color-primary);
    opacity: 0.05;
    line-height: 1;
    user-select: none;
    transition: opacity 0.4s;
  }
  .why-card.active .why-card-num { opacity: 0.1; }
  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.6rem;
  }
  .why-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Prev / Next buttons */
  .carousel-btn {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    background: var(--color-card-bg);
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .carousel-btn svg { width: 20px; height: 20px; }
  .carousel-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
    transform: scale(1.08);
    box-shadow: 0 6px 18px rgba(164, 37, 147, 0.3);
  }

  /* Dots */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }
  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--color-border);
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.3s, width 0.3s;
  }
  .carousel-dot[aria-selected="true"] {
    background: var(--color-accent);
    width: 28px;
    border-radius: 4px;
    transform: scaleY(1.1);
  }

  /* ══════════════════════════════════════
     PROCESS TIMELINE
  ══════════════════════════════════════ */
  .process-title { margin-bottom: 2rem; }
  .process-steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 3.5rem;
    position: relative;
  }
  .process-steps::before {
    content: "";
    position: absolute;
    top: 1.25rem;
    left: 6%;
    right: 6%;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-border));
    z-index: 0;
  }
  .process-steps li { position: relative; z-index: 1; }
  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.85rem;
    box-shadow: 0 8px 18px rgba(164, 37, 147, 0.35);
  }

  /* ══════════════════════════════════════
     CLOSING CTA
  ══════════════════════════════════════ */
  .services-cta {
    text-align: center;
    padding: 3rem 2rem;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #fff;
  }
  .services-cta h3 { color: #fff; margin-bottom: 1.25rem; }
  .services-cta .btn-primary { background: #fff; color: var(--color-primary); }
  .services-cta .btn-primary:hover { background: #f1f1f1; }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 900px) {
    .services-grid, .process-steps { grid-template-columns: 1fr 1fr; }
    .process-steps::before { display: none; }
    /* Tablet: 2 cards visible */
    .why-card { flex: 0 0 calc(50% - 0.63rem); }
  }
  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; }
    .process-steps { grid-template-columns: 1fr 1fr; }
    /* Mobile: 1 card visible */
    .why-card { flex: 0 0 100%; }
    .why-carousel { gap: 0.25rem; padding: 0 0.25rem; }
    .carousel-btn { width: 38px; height: 38px; }
    .carousel-btn svg { width: 18px; height: 18px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-track { transition: none; }
    .why-card, .why-card.active { transform: none !important; animation: none !important; opacity: 1 !important; }
    .why-card.active { border-color: var(--color-accent); box-shadow: none; }
    .why-card.active::after { animation: none !important; transform: scaleX(1); opacity: 1; }
  }
</style>

<script>
(function () {
  const DURATION = 3200;

  const track = document.querySelector(".carousel-track") as HTMLElement | null;
  const cards = Array.from(document.querySelectorAll(".why-card")) as HTMLElement[];
  const dots  = Array.from(document.querySelectorAll(".carousel-dot")) as HTMLButtonElement[];
  const btnPrev = document.querySelector(".carousel-prev") as HTMLButtonElement | null;
  const btnNext = document.querySelector(".carousel-next") as HTMLButtonElement | null;

  if (!track || !cards.length) return;

  cards.forEach(c => c.style.setProperty("--why-duration", DURATION + "ms"));

  const total = cards.length;
  let current = 0;
  let paused  = false;
  let timer   = 0;
  let startX  = 0;

  /* ── How many cards are visible? ── */
  function visibleCount(): number {
    const vw = window.innerWidth;
    if (vw <= 600) return 1;
    if (vw <= 900) return 2;
    return 3;
  }

  /* ── Compute translateX for a given index ── */
  function getOffset(index: number): number {
    const visible = visibleCount();
    const cardEl  = cards[0];
    const gap = 20; // matches 1.25rem gap
    const cardW = cardEl.getBoundingClientRect().width;
    const step  = cardW + gap;

    /* Centre the active card when only 1 visible on mobile */
    if (visible === 1) return index * step;

    /* Otherwise slide so active is the first visible card, but clamp at end */
    const maxOffset = (total - visible) * step;
    return Math.min(index * step, maxOffset);
  }

  function goTo(index: number, instant = false) {
    /* Wrap around */
    current = ((index % total) + total) % total;

    if (instant) track.style.transition = "none";
    track.style.transform = `translateX(-${getOffset(current)}px)`;
    if (instant) void track.offsetWidth; // force reflow

    /* Update card states */
    cards.forEach((card, i) => {
      card.classList.toggle("active", i === current);
    });

    /* Update dots */
    dots.forEach((dot, i) => {
      const active = i === current;
      dot.classList.toggle("active", active);
      dot.setAttribute("aria-selected", active ? "true" : "false");
    });
  }

  function startTimer() {
    clearInterval(timer);
    timer = window.setInterval(() => {
      if (!paused) goTo(current + 1);
    }, DURATION);
  }

  /* Init */
  goTo(0);
  startTimer();

  /* Recalculate on resize */
  let resizeTimer = 0;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => goTo(current, true), 120);
  });

  /* Prev / Next buttons */
  btnPrev?.addEventListener("click", () => {
    goTo(current - 1);
    startTimer();
  });
  btnNext?.addEventListener("click", () => {
    goTo(current + 1);
    startTimer();
  });

  /* Dot clicks */
  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      goTo(i);
      startTimer();
    });
  });

  /* Card click */
  cards.forEach((card, i) => {
    card.addEventListener("click", () => {
      goTo(i);
      startTimer();
    });
  });

  /* Pause on hover (desktop) */
  const section = document.querySelector(".why-us");
  section?.addEventListener("mouseenter", () => { paused = true; });
  section?.addEventListener("mouseleave", () => { paused = false; });

  /* Touch swipe */
  track.addEventListener("touchstart", (e: TouchEvent) => {
    startX = e.touches[0].clientX;
    paused = true;
  }, { passive: true });
  track.addEventListener("touchend", (e: TouchEvent) => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    paused = false;
    startTimer();
  }, { passive: true });
})();
</script>
