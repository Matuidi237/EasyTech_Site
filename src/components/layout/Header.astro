---
import type { Lang } from "../../i18n/utils";
import { useTranslations, getOtherLang } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const otherLang = getOtherLang(lang);

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const navItems = [
  { href: `/${lang}`, label: t.nav.home },
  { href: `/${lang}/about`, label: t.nav.about },
  { href: `/${lang}/services`, label: t.nav.services },
  { href: `/${lang}/realisations`, label: t.nav.realisations },
  { href: `/${lang}/actualites`, label: t.nav.news },
  { href: `/${lang}/contact`, label: t.nav.contact }
];
---

<header class="site-header" role="banner">
  <nav class="navbar container" aria-label="Navigation principale">
    <a href={`/${lang}/`} class="logo" aria-label="EasyTech Group, retour à l'accueil">
      <img src="/images/brand/logo-blue.png" alt="EasyTech Group" />
    </a>

    <ul class="nav-links">
      {navItems.map((item) => (
        <li>
          <a href={item.href} aria-current={currentPath === item.href.replace(/\/$/, "") ? "page" : undefined}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav-controls">
      <a href={`/${otherLang}/`} class="lang-switch" aria-label="Changer de langue">{otherLang.toUpperCase()}</a>
      <a href={`/${lang}/contact`} class="btn btn-primary">{t.nav.cta}</a>
    </div>

    <button id="burger" class="burger" aria-label="Ouvrir le menu" aria-expanded="false">☰</button>
  </nav>
</header>

<style>
  .navbar { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem 1rem 0.5rem; gap: 1.5rem; }

  .logo { display: flex; align-items: center; flex-shrink: 0; }
  .logo img { height: 52px; width: auto; max-width: 180px; object-fit: contain; display: block; }

  .nav-links { display: flex; gap: 1.75rem; list-style: none; }
  .nav-links a { font-weight: 500; font-size: 0.95rem; padding-bottom: 0.3rem; border-bottom: 2px solid transparent; }
  .nav-links a:hover { color: var(--color-accent); }
  .nav-links a[aria-current="page"] { color: var(--color-accent); border-bottom-color: var(--color-accent); }

  .nav-controls { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }
  .lang-switch { background: none; border: 1px solid var(--color-border); border-radius: 6px; padding: 0.35rem 0.6rem; cursor: pointer; color: var(--color-text); font-size: 0.85rem; }
  .burger { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-text); }
  .site-header { position: sticky; top: 0; z-index: 100; }

  @media (max-width: 900px) {
    .wordmark { display: none; }
  }

  @media (max-width: 768px) {
    .nav-links, .nav-controls .btn-primary { display: none; }
    .burger { display: block; }
    .navbar.menu-open .nav-links {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg);
      padding: 1.25rem;
      gap: 1rem;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>

<script is:inline>
  document.getElementById("burger")?.addEventListener("click", function () {
    const nav = this.closest(".navbar");
    const expanded = this.getAttribute("aria-expanded") === "true";
    this.setAttribute("aria-expanded", String(!expanded));
    nav.classList.toggle("menu-open");
  });
</script>
