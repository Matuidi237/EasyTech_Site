const offices = [
  {
    code: "cm",
    country: isEn ? "Cameroon" : "Cameroun",
    city: "Douala",
    address: "B.P 2867 Douala",
    phone: "+237 233 410 701",
  },
  {
    code: "td",
    country: isEn ? "Chad" : "Tchad",
    city: "N'Djamena",
    address: "Immeuble 42 Yantar",
    phone: "+235 90 82 38 83",
  },
  {
    code: "ci",
    country: isEn ? "Côte d'Ivoire" : "Côte d'Ivoire",
    city: "Abidjan",
    address: "211 Rue Jardin Cocody",
    phone: "+225 27 222 895 94",
  },
  {
    code: "sn",
    country: "Sénégal",
    city: "Dakar",
    address: "10137 VDN Villa Sacré Cœur 3",
