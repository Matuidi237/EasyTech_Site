---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/layout/Header.astro";
import Footer from "../../../components/layout/Footer.astro";

const allArticles = await getCollection("articles", ({ data }) => data.lang === "fr");
const articles = allArticles.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout lang="fr" title="Actualités ThinkTech Solutions" description="Les actualités, projets et conseils de ThinkTech Solutions sur l'e-learning en Afrique.">
  <Header lang="fr" />
  <main id="main-content" class="container" style="padding: 4rem 0;">
    <h1>Actualités</h1>
    <ul class="article-list">
      {articles.map((article) => (
        <li>
          <a href={`/fr/actualites/${article.slug.replace(/^fr\//, "")}`}>
            <h2>{article.data.title}</h2>
            <p>{article.data.description}</p>
            <time>{article.data.publishDate.toLocaleDateString("fr-FR")}</time>
          </a>
        </li>
      ))}
    </ul>
  </main>
  <Footer lang="fr" />
</BaseLayout>

<style>
  .article-list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; margin-top: 2rem; }
  .article-list a { display: block; padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px; }
  .article-list time { font-size: 0.85rem; color: var(--color-text-secondary); }
</style>
