---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import Services from "../../components/sections/Services.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "fr";
---

<BaseLayout
  lang={lang}
  title="Nos services ThinkTech Solutions"
  description="Déploiement, hébergement sécurisé, personnalisation, intégrations et support de plateformes Moodle : découvrez l'ensemble de l'expertise ThinkTech Solutions."
>
  <Header lang={lang} />
  <main id="main-content">
    <Services lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
