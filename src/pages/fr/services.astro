---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import Services from "../../components/sections/Services.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "fr";
---

<BaseLayout
  lang={lang}
  title="Nos services EasyTech Group"
  description="Déploiement Moodle Cameroun, hébergement sécurisé, personnalisation et support : l'expertise EasyTech Group pour votre plateforme e-learning à Douala et en Afrique centrale."
>
  <Header lang={lang} />
  <main id="main-content">
    <Services lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
