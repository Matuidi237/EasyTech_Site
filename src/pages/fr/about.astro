---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import About from "../../components/sections/About.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "fr";
---

<BaseLayout
  lang={lang}
  title="À propos — EasyTech Group SA | 10 ans d'expertise IT en Afrique"
  description="Fondée à Douala, EasyTech Group SA est le partenaire IT de référence en Afrique. +100 experts certifiés, +200 fabricants partenaires, présence dans 8 pays africains."
>
  <Header lang={lang} />
  <main id="main-content">
    <About lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
