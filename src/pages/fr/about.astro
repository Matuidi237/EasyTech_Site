---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import About from "../../components/sections/About.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "fr";
---

<BaseLayout
  lang={lang}
  title="À propos EasyTech Group"
  description="Depuis 2024 à Douala, EasyTech Group déploie des plateformes Moodle et e-learning pour les organisations du Cameroun et d'Afrique centrale."
>
  <Header lang={lang} />
  <main id="main-content">
    <About lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
