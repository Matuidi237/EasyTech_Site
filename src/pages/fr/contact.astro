---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import Contact from "../../components/sections/Contact.astro";
import Faq from "../../components/sections/Faq.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "fr";
---

<BaseLayout
  lang={lang}
  title="Demander une démo EasyTech Group"
  description="Demandez une démo de votre plateforme Moodle Cameroun. EasyTech Group, basé à Douala, vous répond en 24-48 h pour votre projet de formation en ligne en Afrique centrale."
>
  <Header lang={lang} />
  <main id="main-content">
    <Contact lang={lang} />
    <Faq lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
