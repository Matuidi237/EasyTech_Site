---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import Services from "../../components/sections/Services.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "en";
---

<BaseLayout
  lang={lang}
  title="Our services ThinkTech Solutions"
  description="Moodle deployment in Cameroon, secure hosting, customization and support: ThinkTech Solutions' expertise for your e-learning platform in Douala and Central Africa."
>
  <Header lang={lang} />
  <main id="main-content">
    <Services lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
