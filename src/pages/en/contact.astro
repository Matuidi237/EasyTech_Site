---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import Contact from "../../components/sections/Contact.astro";
import Faq from "../../components/sections/Faq.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "en";
---

<BaseLayout
  lang={lang}
  title="Request a demo ThinkTech Solutions"
  description="Book a free demo and discover how ThinkTech Solutions can deploy your Moodle platform in a few weeks."
>
  <Header lang={lang} />
  <main id="main-content">
    <Contact lang={lang} />
    <Faq lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
