---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import Hero from "../../components/sections/Hero.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";
import { useTranslations } from "../../i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const serviceIcons = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="4" rx="1"/><rect x="2" y="18" width="6" height="4" rx="1"/><rect x="16" y="18" width="6" height="4" rx="1"/><line x1="12" y1="6" x2="12" y2="10"/><polyline points="12 10 5 20"/><polyline points="12 10 19 20"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L4 6v6c0 5.25 3.6 10.2 8 11.5C16.4 22.2 20 17.25 20 12V6l-8-4z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="5" rx="1"/><rect x="2" y="10" width="20" height="5" rx="1"/><rect x="2" y="17" width="20" height="4" rx="1"/><circle cx="17.5" cy="5.5" r="1"/><circle cx="17.5" cy="12.5" r="1"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1.2" fill="currentColor"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
];
---

<BaseLayout
  lang={lang}
  title="EasyTech Group — IT Solutions for African Businesses"
  description="EasyTech Group SA distributes IT solutions (hardware and software) to equip, secure and scale organizations across Africa. +200 manufacturer partners."
>
  <Header lang={lang} />
  <main id="main-content">
    <Hero lang={lang} />

    <section class="home-trust">
      <div class="container">
        <h2 class="trust-section-title">{t.hero.partnersTitle}</h2>
        <div class="carousel" aria-label={t.hero.partnersTitle}>
          <div class="carousel-track">
            {t.hero.partners.map((p: any) => (
              <div class="partner-logo">
                {p.logo ? (
                  <img src={p.logo} alt={p.name} loading="lazy"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                  <span class="partner-name-badge" style="display:none">{p.name}</span>
                ) : (
                  <span class="partner-name-badge">{p.name}</span>
                )}
              </div>
            ))}
          </div>
        </div>
        <ul class="trust-metrics">
          {t.hero.metrics.map((m: any) => (
            <li><strong class="metric-count" data-value={m.value}>{m.value}</strong><span>{m.label}</span></li>
          ))}
        </ul>
      </div>
    </section>

    <section class="home-about" aria-labelledby="home-about-title">
      <div class="circle-deco home-about-circle-1" aria-hidden="true"></div>
      <div class="circle-deco circle-delay home-about-circle-2" aria-hidden="true"></div>
      <div class="container home-about-grid">
        <div>
          <p class="eyebrow">Our story</p>
          <h2 id="home-about-title">{t.about.title}</h2>
          <p>{t.about.intro}</p>
          <a href={`/${lang}/about`} class="link-arrow">More about EasyTech →</a>
        </div>
        <ul class="home-values">
          {t.about.values.slice(0, 4).map((v: any) => (
            <li><strong>{v.title}</strong><span>{v.text}</span></li>
          ))}
        </ul>
      </div>
    </section>

    <section class="home-services" aria-labelledby="home-services-title">
      <div class="circle-deco home-services-circle-1" aria-hidden="true"></div>
      <div class="circle-deco circle-fill circle-delay home-services-circle-2" aria-hidden="true"></div>
      <div class="container home-services-inner">
        <div class="home-services-text">
          <p class="eyebrow">Our expertise</p>
          <h2 id="home-services-title">{t.services.title}</h2>
          <ol class="home-services-list">
            {t.services.cards.map((c: any, i: number) => (
              <li class="service-item" data-index={i}>
                <span class="svc-icon" set:html={serviceIcons[i]} />
                <div class="service-body">
                  <h3>{c.title}</h3>
                  <p class="service-benefit">{c.benefit}</p>
                  <p class="service-context">{c.points.slice(0, 2).join(' · ')}</p>
                </div>
              </li>
            ))}
          </ol>
          <a href={`/${lang}/services`} class="link-arrow">See all our services →</a>
        </div>
        <div class="tools-orbit" aria-hidden="true">
          <span class="orbit-hub"></span>
          <div class="orbit-ring orbit-ring-1">
            <span class="orbit-icon orbit-icon-counter-1">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </span>
          </div>
          <div class="orbit-ring orbit-ring-2">
            <span class="orbit-icon orbit-icon-counter-2">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><path d="M6 6h.01M6 18h.01"/></svg>
            </span>
          </div>
          <div class="orbit-ring orbit-ring-3">
            <span class="orbit-icon orbit-icon-counter-3">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </span>
          </div>
          <div class="orbit-ring orbit-ring-4">
            <span class="orbit-icon orbit-icon-counter-4">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10 12 5 2 10l10 5 10-5z"/><path d="M6 12v5c0 1.5 3 3 6 3s6-1.5 6-3v-5"/></svg>
            </span>
          </div>
          <div class="orbit-ring orbit-ring-5">
            <span class="orbit-icon orbit-icon-counter-5">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2v6M15 2v6M5 8h14l-1 5a6 6 0 0 1-12 0L5 8z"/><path d="M12 19v3"/></svg>
            </span>
          </div>
        </div>
      </div>
    </section>

    <div class="home-cta-wrap">
      <div class="home-cta-visual reveal" aria-hidden="true">
        <img src="/images/cta/image-bloc-3.png" alt="" width="300" height="300" loading="lazy" />
      </div>
      <section class="home-cta" aria-labelledby="home-cta-title">
        <div class="circle-deco home-cta-circle-1" aria-hidden="true"></div>
        <div class="circle-deco circle-delay home-cta-circle-2" aria-hidden="true"></div>
        <div class="container home-cta-inner">
          <h2 id="home-cta-title">{t.contact.title}</h2>
          <p>{t.contact.subtitle}</p>
          <a href={`/${lang}/contact`} class="btn btn-primary">{t.hero.ctaPrimary}</a>
        </div>
      </section>
    </div>
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>

<style>
  /* ── Trust section ── */
  .home-trust { background: var(--color-bg); padding: 2.5rem 0; border-bottom: 1px solid var(--color-border); }
  .trust-section-title { font-size: 1.1rem; font-weight: 600; color: var(--color-text-secondary); margin-bottom: 1.5rem; }
  .carousel { overflow: hidden; }
  .carousel-track { display: flex; gap: 0; }
  .partner-logo {
    flex: 0 0 160px;
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.25rem;
    border-right: 1px solid var(--color-border);
  }
  .partner-logo img {
    width: 120px;
    height: 56px;
    object-fit: contain;
    object-position: center;
    display: block;
  }
  .partner-name-badge { display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 700; color: var(--color-text); text-align: center; padding: 0.5rem; line-height: 1.2; width: 120px; height: 56px; }
  .trust-metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; list-style: none; margin: 2.5rem 0 0; border-top: 1px solid var(--color-border); }
  .trust-metrics li { padding: 1.5rem 1.25rem 0; border-left: 1px solid var(--color-border); }
  .trust-metrics li:first-child { border-left: none; }
  .trust-metrics strong { display: block; font-size: 2.25rem; font-weight: 800; color: var(--color-accent); }
  .trust-metrics span { color: var(--color-text-secondary); font-size: 0.9rem; }

  .home-about { background: var(--color-bg-secondary); overflow: hidden; }
  .home-about-circle-1 { top: -90px; right: 6%; width: 260px; height: 260px; }
  .home-about-circle-2 { bottom: -120px; left: -60px; width: 200px; height: 200px; }
  .home-about-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.3fr 1fr; gap: 3rem; align-items: start; }
  .home-values { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; border-left: 2px solid var(--color-border); padding-left: 1.5rem; }
  .home-values strong { display: block; font-size: 1.05rem; margin-bottom: 0.25rem; }
  .home-values span { color: var(--color-text-secondary); font-size: 0.92rem; }

  .home-services { overflow: hidden; }
  .home-services-circle-1 { top: 10%; right: -70px; width: 220px; height: 220px; }
  .home-services-circle-2 { bottom: -60px; left: 4%; width: 160px; height: 160px; }
  .home-services-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 240px; gap: 2rem; align-items: center; }
  .home-services-text { min-width: 0; }
  .home-services-list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; margin: 2rem 0; max-width: 720px; }
  .service-item {
    display: flex; gap: 1.25rem; align-items: flex-start;
    border-bottom: 1px solid var(--color-border); padding-bottom: 1.25rem;
    position: relative;
  }
  .service-item.ready {
    transform: scale(0.94) translateY(10px);
    opacity: 0;
    transition: transform 0.55s cubic-bezier(0.22,1,0.36,1), opacity 0.55s ease;
  }
  .service-item.ready.visible { transform: scale(1) translateY(0); opacity: 1; }
  .service-item::before {
    content: '';
    position: absolute; inset: 0;
    border: 1.5px solid transparent;
    pointer-events: none;
    border-radius: 2px;
  }
  .service-item.visible::before {
    animation: gauge-border 1.6s ease-out forwards;
  }
  @keyframes gauge-border {
    0%   { border-color: rgba(126,200,240,0);   box-shadow: none; }
    18%  { border-color: rgba(126,200,240,0.85); box-shadow: 0 0 10px rgba(126,200,240,0.18); }
    100% { border-color: rgba(126,200,240,0.12); box-shadow: none; }
  }
  .svc-icon { flex-shrink: 0; width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; background: rgba(126,200,240,0.1); border-radius: 10px; color: var(--color-accent); margin-top: 0.1rem; }
  .service-body { min-width: 0; }
  .home-services-list h3 { margin-bottom: 0.25rem; }
  .service-benefit { font-size: 0.92rem; margin: 0 0 0.45rem; color: var(--color-text-secondary); }
  .service-context { font-size: 0.8rem; color: var(--color-text-secondary); opacity: 0.7; margin: 0; line-height: 1.5; }

  .link-arrow { font-weight: 600; color: var(--color-accent); display: inline-block; margin-top: 1rem; }
  .link-arrow:hover { text-decoration: underline; }

  .tools-orbit { position: relative; width: 220px; height: 220px; margin: 0 auto; }
  .orbit-hub { position: absolute; top: 50%; left: 50%; width: 54px; height: 54px; margin: -27px 0 0 -27px; border-radius: 50%; background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); box-shadow: 0 14px 28px -10px rgba(2, 33, 121, 0.4); }
  .orbit-ring { position: absolute; top: 50%; left: 50%; border-radius: 50%; border: 1px dashed var(--color-border); }
  .orbit-ring-1 { width: 200px; height: 200px; margin: -100px 0 0 -100px; animation: orbit-spin 18s linear infinite; }
  .orbit-ring-2 { width: 200px; height: 200px; margin: -100px 0 0 -100px; animation: orbit-spin 18s linear infinite; animation-delay: -9s; }
  .orbit-ring-3 { width: 158px; height: 158px; margin: -79px 0 0 -79px; animation: orbit-spin 24s linear infinite reverse; }
  .orbit-ring-4 { width: 158px; height: 158px; margin: -79px 0 0 -79px; animation: orbit-spin 24s linear infinite reverse; animation-delay: -12s; }
  .orbit-ring-5 { width: 112px; height: 112px; margin: -56px 0 0 -56px; animation: orbit-spin 14s linear infinite; }

  .orbit-icon { position: absolute; top: 0; left: 50%; width: 34px; height: 34px; margin-left: -17px; margin-top: -17px; border-radius: 50%; background: var(--color-card-bg); display: flex; align-items: center; justify-content: center; color: var(--color-accent); box-shadow: 0 8px 18px -6px rgba(2, 33, 121, 0.3); }
  .orbit-icon-counter-1 { animation: orbit-spin 18s linear infinite reverse; }
  .orbit-icon-counter-2 { animation: orbit-spin 18s linear infinite reverse; animation-delay: -9s; }
  .orbit-icon-counter-3 { animation: orbit-spin 24s linear infinite; }
  .orbit-icon-counter-4 { animation: orbit-spin 24s linear infinite; animation-delay: -12s; }
  .orbit-icon-counter-5 { animation: orbit-spin 14s linear infinite reverse; color: var(--color-primary); }

  @keyframes orbit-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .home-cta-wrap { position: relative; overflow-x: hidden; overflow-y: visible; }
  .home-cta { position: relative; background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); overflow: hidden; padding: 2.25rem 0; }
  .home-cta-circle-1 { top: -50px; right: -40px; width: 220px; height: 220px; color: var(--color-primary); opacity: 0.1; }
  .home-cta-circle-2 { bottom: -70px; left: 10%; width: 150px; height: 150px; color: var(--color-accent); opacity: 0.1; }
  .home-cta-inner { position: relative; z-index: 1; text-align: center; max-width: 640px; margin: 0 auto; }
  .home-cta h2 { color: var(--color-primary); }
  .home-cta p { color: var(--color-text-secondary); margin-bottom: 1.75rem; }

  .home-cta-visual { position: absolute; right: -28px; top: 0; bottom: 0; z-index: 2; pointer-events: none; }
  .home-cta-visual img {
    height: 100%;
    width: auto;
    display: block;
    filter: drop-shadow(0 18px 26px rgba(2, 33, 121, 0.22));
  }

  @media (max-width: 1100px) {
    .home-cta-visual { display: none; }
  }

  @media (max-width: 900px) {
    .home-about-grid { grid-template-columns: 1fr; }
    .home-values { border-left: none; padding-left: 0; border-top: 2px solid var(--color-border); padding-top: 1.5rem; }
    .home-services-inner { grid-template-columns: 1fr; }
    .tools-orbit { margin-top: 1rem; display: none; }
  }
  @media (max-width: 768px) {
    /* Trust */
    .trust-section-title { font-size: 1rem; margin-bottom: 1rem; }
    .carousel { overflow-x: auto; -webkit-overflow-scrolling: touch; scroll-snap-type: x mandatory; scrollbar-width: none; }
    .carousel::-webkit-scrollbar { display: none; }
    .partner-logo { flex: 0 0 130px; height: 76px; scroll-snap-align: start; }
    .partner-logo img { width: 100px; height: 48px; }
    .trust-metrics { grid-template-columns: repeat(2, 1fr); margin-top: 1.75rem; }
    .trust-metrics li { border-left: none; border-top: 1px solid var(--color-border); padding: 1.25rem 0.75rem 0; }
    .trust-metrics li:nth-child(1), .trust-metrics li:nth-child(2) { border-top: none; }
    .trust-metrics strong { font-size: 1.85rem; }
    .trust-metrics span { font-size: 0.82rem; }

    /* About */
    .home-about-grid { gap: 1.75rem; }

    /* Services */
    .home-services-list { gap: 1.25rem; margin: 1.5rem 0; }
    .service-item { gap: 1rem; padding-bottom: 1.1rem; }
    .svc-icon { width: 38px; height: 38px; border-radius: 8px; }
    .svc-icon svg { width: 22px; height: 22px; }
    .service-benefit { font-size: 0.88rem; }
    .service-context { font-size: 0.78rem; }

    /* CTA */
    .home-cta-inner { padding: 0 1rem; }
  }

  @media (max-width: 480px) {
    .partner-logo { flex: 0 0 115px; height: 68px; }
    .partner-logo img { width: 88px; height: 42px; }
    .svc-icon { width: 34px; height: 34px; border-radius: 7px; }
    .svc-icon svg { width: 20px; height: 20px; }
    .service-item { gap: 0.85rem; }
    .home-services-list h3 { font-size: 0.95rem; }
  }
</style>

<script is:inline>
(function () {
  var svcObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        var delay = (parseInt(entry.target.dataset.index) || 0) * 90;
        setTimeout(function () { entry.target.classList.add('visible'); }, delay);
        svcObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.service-item').forEach(function (el) {
    el.classList.add('ready');
    svcObserver.observe(el);
  });
})();
</script>

<script is:inline>
(function () {
  function parseMetric(raw) {
    var prefix = raw.match(/^[^0-9]*/)[0];
    var suffix = raw.match(/[^0-9]*$/)[0];
    var num = parseFloat(raw.replace(/[^0-9.]/g, ''));
    return { prefix: prefix, suffix: suffix, num: isNaN(num) ? 0 : num };
  }

  function animateCount(el) {
    var raw = el.getAttribute('data-value') || el.textContent;
    var p = parseMetric(raw);
    var duration = 1800;
    var start = null;
    function step(ts) {
      if (!start) start = ts;
      var progress = Math.min((ts - start) / duration, 1);
      var ease = 1 - Math.pow(1 - progress, 3);
      var current = Math.round(ease * p.num);
      el.textContent = p.prefix + current + p.suffix;
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        animateCount(entry.target);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.4 });

  document.querySelectorAll('.metric-count').forEach(function (el) {
    observer.observe(el);
  });
})();
</script>
