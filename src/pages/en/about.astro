---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import About from "../../components/sections/About.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "en";
---

<BaseLayout
  lang={lang}
  title="About ThinkTech Solutions"
  description="Since 2024 in Douala, ThinkTech Solutions supports universities, companies and NGOs in deploying Moodle training platforms across Africa."
>
  <Header lang={lang} />
  <main id="main-content">
    <About lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
