---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import About from "../../components/sections/About.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "en";
---

<BaseLayout
  lang={lang}
  title="About — EasyTech Group SA | 10 years of IT expertise in Africa"
  description="Founded in Douala, EasyTech Group SA is Africa's reference IT partner. 100+ certified experts, 200+ manufacturer partners, presence in 8 African countries."
>
  <Header lang={lang} />
  <main id="main-content">
    <About lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
