---
import "../styles/global.css";
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;
const canonical = `https://thinktech-solutions.com${Astro.url.pathname}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "ThinkTech Solutions",
  image: "https://thinktech-solutions.com/logo.svg",
  url: "https://thinktech-solutions.com",
  telephone: "+237689357969",
  email: "contact@thinktech-solutions.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Douala",
    addressCountry: "CM"
  },
  description: "ThinkTech Solutions conçoit et déploie des plateformes de formation Moodle sécurisées en Afrique."
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="fr" href="https://thinktech-solutions.com/fr/" />
  <link rel="alternate" hreflang="en" href="https://thinktech-solutions.com/en/" />
  <link rel="alternate" hreflang="x-default" href="https://thinktech-solutions.com/fr/" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://thinktech-solutions.com/images/og-cover.jpg" />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={lang === "fr" ? "fr_FR" : "en_US"} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <link rel="icon" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.webmanifest" />

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</head>
<body>
  <a href="#main-content" class="skip-link">Aller au contenu principal</a>
  <slot />
  <script is:inline src="/scripts/reveal.js"></script>
</body>
</html>
